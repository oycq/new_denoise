# Build / runtime artefacts -------------------------------------------------
# ---------------------------------------------------------------------------

__pycache__/
*.pyc
*.log

# ---------------------------------------------------------------------------
# Data, weights, results (large, regenerable, never committed) -------------
# ---------------------------------------------------------------------------

#train_data/
checkpoints/
result/

# ---------------------------------------------------------------------------
# Past experiment artefacts -------------------------------------------------
# ---------------------------------------------------------------------------
# `experiments/` contains the historical sweep outputs (model.pt + ISP
# renders + per-strategy summary.json) from the work documented in
# `docs/EXPERIMENTS_JOURNEY.md`. The distilled knowledge (reports, comparison
# images) lives under `docs/` and is tracked; the raw experiment data is
# kept locally for reference but not pushed.
experiments/

# Local-only scripts kept for reproducing past experiments. They live under
# `archive/` so the project root stays focused on production code (n2n/,
# benchmark.py, run_train.py, train_gui.py).
archive/

# Distribution archives produced by `git archive ...` for handing off the
# repo to other machines.
*.zip
*.tar.gz

# ---------------------------------------------------------------------------
# Editor / OS noise ---------------------------------------------------------
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
